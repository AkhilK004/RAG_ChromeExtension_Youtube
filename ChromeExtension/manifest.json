{
  "manifest_version": 3,
  "name": "YouTube RAG Assistant",
  "version": "1.0.0",
  "description": "Ask questions about the current YouTube video using your local RAG backend.",
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "https://chromeextensionrag-youtube.onrender.com/*",
    "*://*.youtube.com/*",
    "http://127.0.0.1:8000/*"
  ],
  "action": {
    "default_title": "YouTube RAG",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}